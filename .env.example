# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/finance.db

# ── Gmail OAuth2 ─────────────────────────────────────────────────────────────
# Path to the OAuth2 credentials JSON downloaded from Google Cloud Console
GMAIL_CREDENTIALS_FILE=secrets/credentials.json
# Path where the authorised token will be stored after first login
GMAIL_TOKEN_FILE=secrets/token.json

# ── Ingestion ─────────────────────────────────────────────────────────────────
# How many seconds to wait between polls in --poll mode
POLL_SECONDS=300
# Default look-back window on first run (days)
INITIAL_LOOKBACK_DAYS=30

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Set to "development" or "production"
ENV=development
